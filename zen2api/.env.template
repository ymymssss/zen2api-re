# Zen2API Configuration
# Copy this file to .env and fill in your values

# Server Configuration
ZEN2API_HOST=127.0.0.1
ZEN2API_PORT=9015

# API Key (optional - leave empty to disable auth)
ZEN2API_KEY=

# Upstream URLs (defaults work for most users)
# ZEN2API_ZEN_UPSTREAM_URL=https://opencode.ai/zen/v1/messages
# ZEN2API_ZEN_MODELS_URL=https://opencode.ai/zen/v1/models
# ZEN2API_KILO_UPSTREAM_URL=https://api.kilo.ai/api/openrouter/chat/completions
# ZEN2API_KILO_MODELS_URL=https://api.kilo.ai/api/openrouter/models

# Model Discovery
ZEN2API_MODEL_DISCOVERY_ENABLED=true
ZEN2API_MODEL_DISCOVERY_TTL_SECONDS=3600

# Logging
ZEN2API_LOG_LEVEL=INFO
# ZEN2API_LOG_FILE=zen2api.log

# Stats
ZEN2API_STATS_FILE=stats.json
ZEN2API_STATS_LOG_INTERVAL=3600
